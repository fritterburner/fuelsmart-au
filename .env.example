# Upstash Redis (get from upstash.com after creating a free database)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QLD FPD API
QLD_FPD_API_TOKEN=

# NSW FuelCheck API (apply at api.nsw.gov.au)
NSW_FUEL_API_KEY=
NSW_FUEL_API_SECRET=

# Cron secret (generate a random string for production)
CRON_SECRET=

# OpenRouteService — fallback routing provider when the public OSRM demo
# server is down. Sign up at openrouteservice.org/dev/#/signup for a free key
# (2,000 requests/day on the evaluation tier). Optional — if blank, OSRM is the
# only provider and outages surface to the user.
OPENROUTESERVICE_API_KEY=

# --- National coverage (added 2026-06-15) ---
# VIC Servo Saver Open API (Service Victoria). Set once your API Consumer ID is
# approved; the VIC fetcher stays dormant until this is present.
VIC_SERVO_SAVER_API_KEY=
# Optional override if the documented endpoint differs from the default.
VIC_SERVO_SAVER_URL=

# SA Fuel Pricing Information Scheme (Informed Sources aggregator). Set once you
# are an authorised data publisher; the SA fetcher stays dormant until present.
SA_FPIS_API_TOKEN=
SA_FPIS_URL=

# Bearer secret protecting GET /api/usage/report (the SA aggregate usage report).
USAGE_REPORT_SECRET=

# Bearer secret for the one-off historical backfill endpoint
# (GET /api/admin/backfill-history). Set it, run the backfill, then delete the
# route on the next commit — the data persists in Redis.
BACKFILL_SECRET=
